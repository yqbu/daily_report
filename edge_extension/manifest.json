{
  "manifest_version": 3,
  "name": "Daily Report Browser Event Collector",
  "version": "0.2.0",
  "description": "Collect lightweight browser activity events and AI prompt submissions for local daily_report only.",
  "host_permissions": [
    "http://localhost:8765/*",
    "http://127.0.0.1:8765/*",
    "http://*/*",
    "https://*/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://chat.deepseek.com/*"
  ],
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
