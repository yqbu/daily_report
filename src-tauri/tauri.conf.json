{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daily Report",
  "version": "0.1.0",
  "identifier": "com.yqbu.daily-report",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Daily Report",
        "width": 1280,
        "height": 800,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
