{
  "name": "daily-report-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "tauri:dev": "cross-env VITE_API_MODE=tauri tauri dev",
    "tauri:dev:sidecar": "cross-env VITE_API_MODE=tauri DAILY_REPORT_TAURI_START_API=1 tauri dev",
    "tauri:build": "cross-env VITE_API_MODE=tauri tauri build",
    "gui": "npm run tauri:dev:sidecar"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "cross-env": "^7.0.3"
  }
}
